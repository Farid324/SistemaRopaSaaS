// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ═══════════════════ ENUMS ═══════════════════

enum Rol {
  SUPER_ADMIN
  OWNER_PRINCIPAL
  CO_OWNER
  ADMINISTRADOR
  EMPLEADO
}

enum EstadoGeneral {
  ACTIVO
  BLOQUEADO
  CERRADO
}

enum MetodoPago {
  EFECTIVO
  QR
  TARJETA
}

enum TipoCodigo {
  BARRAS
  QR
  MANUAL
}

enum EstadoPrenda {
  NUEVO
  SEMI_NUEVO
  USADO
}

enum EstadoVenta {
  DISPONIBLE
  VENDIDO
  RESERVADO
}

// ═══════════════════ TABLAS ═══════════════════

model PlanSuscripcion {
  id              String    @id @default(uuid())
  nombre          String    // Semilla, Crecimiento, Corporativo
  precioBsMensual Float     @default(0)
  precioBsTrimestral Float? // solo Crecimiento
  precioBsAnual   Float?
  limitePrendas   Int
  limiteSucursal  Int
  limiteEmpleados Int       @default(2)
  accesoWeb       Boolean   @default(false) // Semilla = false
  empresas        Empresa[]
}

model Empresa {
  id            String   @id @default(uuid())
  nombre        String
  fechaRegistro DateTime @default(now())

  planId String
  plan   PlanSuscripcion @relation(fields: [planId], references: [id])

  sucursales Sucursal[]
  usuarios   Usuario[]
  prendas    Prenda[]
  ventas     Venta[]
}

model Sucursal {
  id                  String        @id @default(uuid())
  nombre              String
  direccion           String?
  detalles            String?
  horarios            String?       @default("08:00 - 20:00")
  maxAdministradores  Int           @default(2)
  estado              EstadoGeneral @default(ACTIVO)

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id])

  usuarios Usuario[]
  prendas  Prenda[]
  ventas   Venta[]
}

model Usuario {
  id                   String        @id @default(uuid())
  nombreCompleto       String
  ci                   String        @unique
  correo               String        @unique
  telefono             String?
  edad                 Int?
  fechaIngreso         DateTime      @default(now())
  fotoPerfil           String?
  password             String        // Inicialmente = CI
  debeCambiarPass      Boolean       @default(true)
  rol                  Rol
  estado               EstadoGeneral @default(ACTIVO)
  permisoEditarPrendas Boolean       @default(false) // Solo relevante para EMPLEADO

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id])

  sucursalId       String?
  sucursal         Sucursal? @relation(fields: [sucursalId], references: [id])

  ventasRealizadas Venta[]   @relation("Vendedor")
}

model Prenda {
  id          String       @id @default(uuid())
  codigo      String       @unique
  tipoCodigo  TipoCodigo   @default(MANUAL)
  marca       String?
  tipo        String       // Blusa, Pantalón, Vestido, etc.
  detalles    String?
  estado      EstadoPrenda @default(NUEVO)
  foto        String?
  precio      Float
  rebaja      Float?
  estadoVenta EstadoVenta  @default(DISPONIBLE)
  publicadoWeb Boolean     @default(false)

  empresaId  String
  empresa    Empresa  @relation(fields: [empresaId], references: [id])
  sucursalId String
  sucursal   Sucursal @relation(fields: [sucursalId], references: [id])

  detallesVenta DetalleVenta[]
}

model Venta {
  id           String   @id @default(uuid())
  fecha        DateTime @default(now())
  totalCobrado Float

  empresaId  String
  empresa    Empresa  @relation(fields: [empresaId], references: [id])
  sucursalId String
  sucursal   Sucursal @relation(fields: [sucursalId], references: [id])
  vendedorId String
  vendedor   Usuario  @relation("Vendedor", fields: [vendedorId], references: [id])

  detallesPrendas DetalleVenta[]
  metodosDePago   PagoVenta[]
}

model DetalleVenta {
  id            String @id @default(uuid())
  ventaId       String
  venta         Venta  @relation(fields: [ventaId], references: [id])
  prendaId      String
  prenda        Prenda @relation(fields: [prendaId], references: [id])
  precioVendido Float
}

model PagoVenta {
  id      String     @id @default(uuid())
  ventaId String
  venta   Venta      @relation(fields: [ventaId], references: [id])
  metodo  MetodoPago
  monto   Float
}